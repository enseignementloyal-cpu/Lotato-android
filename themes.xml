<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.LotatoPro" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:windowBackground">@color/bg</item>
        <item name="android:statusBarColor">@color/bg</item>
        <item name="android:navigationBarColor">@color/bg</item>
        <item name="android:textColor">@color/text_main</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="ChipButton">
        <item name="android:paddingStart">14dp</item>
        <item name="android:paddingEnd">14dp</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingBottom">8dp</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/text_dim</item>
        <item name="android:background">@drawable/chip_bg</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="ChipButton.Active">
        <item name="android:textColor">@color/white</item>
        <item name="android:background">@drawable/chip_active_bg</item>
    </style>
</resources>
